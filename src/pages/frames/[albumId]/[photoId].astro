---
import Layout from "../../../layouts/Layout.astro";
import PhotoDetail from "../../../components/PhotoDetail";
import {
    fetchExhibitManifest,
    getPhotoNavigation,
} from "../../../lib/exhibit-data";

export async function getStaticPaths() {
    const manifest = await fetchExhibitManifest();
    const enableGallerySales = manifest.exhibit_info?.enable_gallery_sales !== false;

    return manifest.albums.flatMap((album) => {
        return album.photos.map((photo) => {
            const nav = getPhotoNavigation(album, photo.lightroom_id);
            return {
                params: { albumId: album.id, photoId: photo.lightroom_id },
                props: { photo, nav, albumId: album.id, enableGallerySales },
            };
        });
    });
}

const { photo, nav, albumId, enableGallerySales } = Astro.props;
const displayTitle = photo.metadata?.title || photo.title || "Untitled";
---

<Layout title={displayTitle}>
    <PhotoDetail client:load photo={photo} nav={nav} albumId={albumId} enableGallerySales={enableGallerySales} />
</Layout>
